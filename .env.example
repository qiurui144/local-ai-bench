# vlm-llm-benchmark 环境变量配置模板
# 复制为 .env（gitignored）并填写实际值，或直接 export 到 shell
#
# 用法：cp .env.example .env && edit .env && source .env
# 或：  export OLLAMA_AMD_BASE_URL=http://<amd-windows-ip>:11434/v1

# ── AMD Windows laptop ───────────────────────────────────────────────────────
# 设备 IP / 用户 / 密码只放本地环境，不写进代码或 models.yaml
AMD_HOST=<amd-windows-ip>
AMD_SSH_USER=your-windows-user
AMD_SSH_PASS=your-windows-password
OLLAMA_AMD_BASE_URL=http://<amd-windows-ip>:11434/v1

# ── Intel Windows laptop ─────────────────────────────────────────────────────
INTEL_WIN_HOST=<intel-windows-ip>
INTEL_WIN_SSH_USER=your-windows-user
INTEL_WIN_SSH_PASS=your-windows-password
OLLAMA_INTEL_WIN_BASE_URL=http://<intel-windows-ip>:11434/v1

# ── Intel Linux（CPU-only，Ollama）───────────────────────────────────────────
INTEL_LINUX_HOST=<intel-linux-ip>
INTEL_LINUX_SSH_USER=your-linux-user
INTEL_LINUX_SSH_PASS=your-linux-password
OLLAMA_INTEL_LINUX_BASE_URL=http://<intel-linux-ip>:11434/v1

# ── Rockchip RK3588（linaro@192.168.100.206）+ RK182X NPU ───────────────────
RK3588_HOST=192.168.100.206
RK3588_USER=linaro
RK3588_PASS=<rk3588-password>
RK3588_LLM_BASE_URL=http://192.168.100.206:8080/v1    # rknn_adapter 端口
RK182X_LLM_BASE_URL=http://192.168.100.206:8090/v1    # RK182X 独立 NPU 端口

# ── SpacemiT K3 RISC-V（bianbu@192.168.100.140，16GB）───────────────────────
K3_HOST=192.168.100.140
K3_USER=bianbu
K3_PASS=<k3-password>
K3_LLM_BASE_URL=http://192.168.100.140:8080/v1        # llama-server 端口

# ── SpacemiT K1 RISC-V（与 K3 同机架或同机，端口区分）──────────────────────────
K1_HOST=192.168.100.140
K1_USER=bianbu
K1_PASS=<k1-password>
K1_LLM_BASE_URL=http://192.168.100.140:8081/v1        # K1 llama-server 端口

# ── 本地 vLLM / llama.cpp 端口（可选，默认值已内置）──────────────────────────
# VLLM_PORT=8000
# LLAMA_CPP_PORT=8080

# ── 云端 API Keys（按需填写对应 provider）────────────────────────────────────
# DEEPSEEK_API_KEY=sk-...
# DASHSCOPE_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
