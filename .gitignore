# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.Python
.venv/
venv/
env/

# Build / dist
build/
builds/
dist/
*.tar.gz
*.zip

# ML artifacts (large; reproduce with prepare_offline.sh)
models/
wheels/
hf_cache/
output/
deps/*.deb

# Fixtures often contain PII — never commit real images
fixtures/*.jpg
fixtures/*.jpeg
fixtures/*.png
fixtures/*.gif
fixtures/*.webp
fixtures/*.pdf
fixtures/*.mp4
fixtures/*.wav
# but DO commit fixtures/README.md and any synthetic demo data
!fixtures/README.md

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Local secrets — never commit
.env
.env.local
*.pem
*.key
.sdlc/
reports/runs/

# Local AI-session config — machine-specific, never commit
.claude/

# Project AI instructions — machine-specific paths (HDD symlinks, device IPs), never commit
CLAUDE.md

# Intermediate process outputs — NOT committed.
# Only fixed-name landing reports (reports/{platform}.{en,zh}.md + model-matrix.*) are committed.
# Date-stamped files are local-only audit/health/coverage records.
reports/2[0-9][0-9][0-9]-*
reports/2[0-9][0-9][0-9]/

# output/ run JSON records (large, reproducible)
output/reports/

# AI session scratch dirs — machine-specific, never commit
.remember/
.remember/*

# __pycache__ at any depth
**/__pycache__/

# Synthetic (renderer-generated) scenario screenshots — no PII, committed
!fixtures/scenarios/
!fixtures/scenarios/**/*.png
drivers
