{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rv-bianbu-nas.local/schemas/evaluation-contract.schema.json",
  "title": "VLM/LLM NAS Evaluation Contract",
  "type": "object",
  "required": [
    "schema_version",
    "contract_id",
    "contract_version",
    "date",
    "status",
    "output_schema",
    "verdict_enum",
    "targets",
    "execution_policy",
    "common_admission_axes",
    "required_result_profiles",
    "summary_stat_required",
    "environment_required",
    "test_items",
    "scheduler_fields_waiting_for_matrix",
    "scheduler_output_contract"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "contract_id": {
      "type": "string",
      "const": "vlm-llm-nas-evaluation-contract"
    },
    "contract_version": {
      "type": "integer",
      "const": 1
    },
    "date": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "authoritative_for_future_outputs",
        "deprecated"
      ]
    },
    "output_schema": {
      "type": "object",
      "required": [
        "parameter_matrix_schema",
        "run_summary_schema",
        "model_profile_schema",
        "scheduler_contract_schema",
        "required_top_level_fields",
        "required_row_fields",
        "required_artifacts",
        "verdict_table_columns"
      ],
      "additionalProperties": true
    },
    "verdict_enum": {
      "type": "array",
      "minItems": 7,
      "contains": {
        "const": "blocked"
      },
      "items": {
        "type": "string",
        "enum": [
          "sync_default",
          "sync_bounded",
          "async_default",
          "async_only",
          "offline_only",
          "not_recommended",
          "blocked"
        ]
      },
      "uniqueItems": true
    },
    "targets": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": [
          "target",
          "os",
          "phase",
          "status",
          "purpose"
        ],
        "properties": {
          "target": {
            "type": "string",
            "enum": [
              "amd-win-x86",
              "intel-win-x86",
              "amd-linux-x86",
              "intel-linux",
              "k3-riscv-16g",
              "k3-riscv-32g"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "test_items": {
      "type": "array",
      "minItems": 12,
      "items": {
        "type": "object",
        "required": [
          "test_item_id",
          "task_class",
          "targets",
          "parameter_axes",
          "scheduler_derivations"
        ],
        "properties": {
          "test_item_id": {
            "type": "string",
            "enum": [
              "llm_chat_boundary",
              "llm_summary_boundary",
              "embedding_retrieval",
              "reranker_candidates",
              "rag_answer_defaults",
              "rag_search_only_fallback",
              "vlm_image_qa_boundary",
              "vlm_document_extract_boundary",
              "ocr_pages",
              "asr_duration_concurrency",
              "mixed_nas_load",
              "soak_recommended_profiles"
            ]
          },
          "task_class": {
            "type": "string"
          },
          "targets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "parameter_axes": {
            "type": "object",
            "minProperties": 1
          },
          "scheduler_derivations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "scheduler_output_contract": {
      "type": "object",
      "required": [
        "model_profile_top_level_required",
        "model_task_profile_required",
        "estimated_runtime_ms_required",
        "hot_set_profile_required",
        "rag_defaults_required",
        "vlm_sync_boundary_required",
        "ui_timeout_profile_required"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
